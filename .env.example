# OpenAI-compatible API (required only when LLM segmentation is triggered)
OPENAI_API_KEY=
# Optional: Azure OpenAI or other compatible endpoints.
# 不要使用空行 OPENAI_BASE_URL= —— 空字符串会导致 SDK 请求 URL 无效；不需要时请整行删除或保持注释。
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model and generation
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=120

# When to invoke LLM on a candidate unit (see README)
MAX_UNIT_CHARS_SKIP_LLM=3500
MIN_CHARS_MULTI_TOPIC_HEURISTIC=4500
GENERIC_TITLE_PATTERNS=overview,introduction,programs,new initiatives,updates,news,about us,our work

# Embedding chunk packing (sentence groups; not arbitrary character splits)
MAX_CHUNK_CHARS_SOFT=1800
MAX_SENTENCES_PER_GROUP=8

# HTTP client
HTTP_TIMEOUT_SECONDS=30
HTTP_USER_AGENT=raw-to-embedding-agent/1.0

DEFAULT_OUTPUT_DIR=./output
